# Tournament passcode — all players use this to sign in.
TRIP_PASSCODE=pinehurst2026

# Session cookie signing secret. Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-32-random-hex-chars

# Where the SQLite file lives. Default: ./data/invitational.db
DB_PATH=./data/invitational.db

# Public-facing URL used in any absolute links.
NEXT_PUBLIC_SITE_URL=https://np.huffmanai.com
